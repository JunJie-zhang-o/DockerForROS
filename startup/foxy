#!/usr/bin/env bash
set -euo pipefail

SERVICE_NAME="ros-foxy-focal"
COMPOSE_FILE="docker-compose.yml"
CONTAINER_NAME="ros-foxy-focal"

usage() {
  cat <<'USAGE'
Usage: foxy [start|stop|enter|restart|status]

No argument: interactive menu.
USAGE
}

ensure_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "Error: docker command not found"
    exit 1
  fi

  if ! docker compose version >/dev/null 2>&1; then
    echo "Error: docker compose is not available"
    exit 1
  fi

  if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Error: $COMPOSE_FILE not found in current directory"
    exit 1
  fi
}

xhost_allow() {
  if command -v xhost >/dev/null 2>&1; then
    xhost +local:docker >/dev/null 2>&1 || true
  fi
}

container_running() {
  docker inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null | grep -q '^true$'
}

do_start() {
  xhost_allow
  docker compose up -d "$SERVICE_NAME"
  echo "Started: $CONTAINER_NAME"
}

do_stop() {
  docker compose stop "$SERVICE_NAME"
  echo "Stopped: $CONTAINER_NAME"
}

do_enter() {
  xhost_allow
  if ! container_running; then
    docker compose up -d "$SERVICE_NAME"
  fi
  docker compose exec "$SERVICE_NAME" /bin/zsh
}

do_restart() {
  xhost_allow
  docker compose restart "$SERVICE_NAME"
  echo "Restarted: $CONTAINER_NAME"
}

do_status() {
  if container_running; then
    echo "Status: running"
  else
    echo "Status: stopped"
  fi
}

interactive_menu() {
  echo "请输入指令控制 ${CONTAINER_NAME}: 启动(s) 重启(r) 进入(e) 关闭(c) 状态(t)"
  read -r choose
  case "$choose" in
    s) do_start ;;
    r) do_restart ;;
    e) do_enter ;;
    c) do_stop ;;
    t) do_status ;;
    *)
      echo "无效选项: $choose"
      usage
      exit 1
      ;;
  esac
}

main() {
  ensure_docker

  if [ $# -eq 0 ]; then
    interactive_menu
    return 0
  fi

  case "$1" in
    start|s) do_start ;;
    stop|c) do_stop ;;
    enter|exec|e) do_enter ;;
    restart|r) do_restart ;;
    status|t) do_status ;;
    -h|--help|help) usage ;;
    *)
      echo "Invalid argument: $1"
      usage
      exit 1
      ;;
  esac
}

main "$@"
