#!/usr/bin/env bash
set -euo pipefail

DEFAULT_VARIANT="focal"
VARIANT="$DEFAULT_VARIANT"
SERVICE_NAME=""
CONTAINER_NAME=""
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMON_SCRIPT="$SCRIPT_DIR/../scripts/startup_ros.sh"

usage() {
  cat <<'USAGE'
Usage: noetic [focal|jammy] [start|stop|enter|restart|status]
       noetic [start|stop|enter|restart|status]

No argument: interactive menu.
USAGE
}

set_target() {
  case "$1" in
    focal)
      VARIANT="focal"
      SERVICE_NAME="ros-noetic-focal"
      CONTAINER_NAME="ros-noetic-focal"
      ;;
    jammy)
      VARIANT="jammy"
      SERVICE_NAME="ros-noetic-jammy"
      CONTAINER_NAME="ros-noetic-jammy"
      ;;
    *)
      echo "Invalid noetic variant: $1"
      usage
      exit 1
      ;;
  esac
}

choose_variant_interactive() {
  echo "请选择 noetic 容器版本: focal(f) jammy(j)"
  read -r v
  case "$v" in
    f|focal|"") set_target "focal" ;;
    j|jammy) set_target "jammy" ;;
    *)
      echo "无效版本: $v"
      exit 1
      ;;
  esac
}

dispatch_action() {
  exec bash "$COMMON_SCRIPT" "$SERVICE_NAME" "$CONTAINER_NAME" "$1"
}

interactive_menu() {
  choose_variant_interactive
  echo "请输入指令控制 ${CONTAINER_NAME}: 启动(s) 重启(r) 进入(e) 关闭(c) 状态(t)"
  read -r choose
  dispatch_action "$choose"
}

main() {
  if [ ! -f "$COMMON_SCRIPT" ]; then
    echo "Error: $COMMON_SCRIPT not found"
    exit 1
  fi

  if [ $# -eq 0 ]; then
    interactive_menu
    return 0
  fi

  case "$1" in
    focal|jammy)
      set_target "$1"
      if [ $# -eq 1 ]; then
        echo "请输入指令控制 ${CONTAINER_NAME}: 启动(s) 重启(r) 进入(e) 关闭(c) 状态(t)"
        read -r choose
        dispatch_action "$choose"
      else
        dispatch_action "$2"
      fi
      ;;
    start|stop|enter|exec|restart|status|s|c|e|r|t)
      set_target "$DEFAULT_VARIANT"
      dispatch_action "$1"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      echo "Invalid argument: $1"
      usage
      exit 1
      ;;
  esac
}

main "$@"
